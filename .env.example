# Alley Agent Web — Environment Variables

# Server
PORT=3000
SESSION_SECRET=change-this-to-a-random-string

# Database — Turso (free persistent cloud SQLite)
# Get credentials at: https://turso.tech
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Admin credentials (pre-seeded on first run)
ADMIN_USERNAME=DAVIDALLEY
ADMIN_PASSWORD=Passwerd1

# LLM Provider — Groq (free tier, fast, no credit card needed)
# Get your key at: https://console.groq.com
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=your-groq-key-here

# Optional: swap to other providers by changing LLM_PROVIDER and setting the key
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash
# GEMINI_API_KEY=your-gemini-key

# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3

# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-your-key-here

# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Stripe (credit/debit card payments — instant activation, no admin approval needed)
# Get your keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
# Webhook secret — set after creating webhook in Stripe dashboard
# https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Payment links
PAYPAL_ME_LINK=https://paypal.me/DavidAlleyWay
CRYPTO_WALLET_LTC=ltc1qqkznja520xrwaqmc54vk84prfdtnxnmkceh6kq
CRYPTO_WALLET_BTC=bc1qa3u30zsr34ha0q9kaqlf4rnhhcjn5raeuthysm

# Admin email alerts (password change notifications)
# Uses Resend.com — free tier, 100 emails/day, sign up with GitHub
# Get your API key at: https://resend.com/api-keys
ADMIN_EMAIL=davidalleyway@gmail.com
RESEND_API_KEY=re_your_resend_api_key

# Developer Mode — Self-modifying code agent (admin only)
# GitHub PAT for pushing code changes (needs repo read/write access)
GITHUB_PAT=github_pat_your_token_here
# Render API key for triggering auto-deploy after push
RENDER_API_KEY=rnd_your_render_api_key
